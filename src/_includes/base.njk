<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — GeneXus Blog</title>
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if feed %}<link rel="alternate" type="application/atom+xml" href="/feed.xml" title="GeneXus Blog">{% endif %}
</head>
<body>
  <header>
    <nav>
      <a href="/">GeneXus Blog</a>
    </nav>
    {% set translations = collections.all | getTranslations(translationKey, lang) %}
    {% if translations.length %}
    <ul class="language-switcher">
      {% for post in translations %}
      <li><a href="{{ post.url }}" lang="{{ post.data.lang }}" hreflang="{{ post.data.lang }}">{{ i18n.languages[post.data.lang].label }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>&copy; {{ page.date.getFullYear() }} GeneXus</p>
  </footer>
</body>
</html>
